# SoloAdventurer Web App Environment Variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Amazon Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-client-id
COGNITO_IDENTITY_POOL_ID=us-east-1:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# AWS AppSync GraphQL
GRAPHQL_ENDPOINT=https://xxxxxxxxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
GRAPHQL_API_KEY=your-graphql-api-key

# Amazon S3
S3_BUCKET=solo-adventurer-media
S3_REGION=us-east-1

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Sentry (Optional)
SENTRY_DSN=your-sentry-dsn

# Feature Flags
NEXT_PUBLIC_ENABLE_MAP_CLUSTERING=true
NEXT_PUBLIC_ENABLE_REALTIME_CHAT=true
NEXT_PUBLIC_ENABLE_AI_MATCHING=true