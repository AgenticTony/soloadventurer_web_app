{
  "name": "soloadventurer-web-app",
  "version": "1.0.0",
  "description": "A social platform for solo travelers",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy": "next build && next start",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "e2e": "cypress run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "travel",
    "social",
    "nextjs",
    "react",
    "typescript"
  ],
  "author": "SoloAdventurer Team",
  "license": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.0.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/mapbox-gl": "^3.4.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.460.0",
    "mapbox-gl": "^3.15.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.396.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.4.0",
    "react-intersection-observer": "^9.5.0",
    "react-simple-maps": "^3.0.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-simple-maps": "^3.0.6",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.25.9",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.1.6",
    "next-router-mock": "^1.0.2",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn": "^3.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "@testing-library/dom": "^10.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "react-simple-maps": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
