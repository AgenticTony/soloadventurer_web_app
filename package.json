{
  "name": "soloadventurer-web-app",
  "version": "1.0.0",
  "description": "A social platform for solo travelers",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy": "next build && next start",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "e2e": "cypress run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "travel",
    "social",
    "nextjs",
    "react",
    "typescript",
    "aws"
  ],
  "author": "SoloAdventurer Team",
  "license": "MIT",
  "dependencies": {
    "@apollo/client": "^3.8.0",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.0.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/mapbox-gl": "^3.4.1",
    "allotment": "^1.20.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "emoji-picker-react": "^4.13.3",
    "framer-motion": "^11.11.0",
    "graphql": "^15.8.0",
    "immer": "^10.1.3",
    "lucide-react": "^0.460.0",
    "mapbox-gl": "^3.15.0",
    "next": "^15.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.4.0",
    "react-intersection-observer": "^9.5.0",
    "react-simple-maps": "^3.0.0",
    "react-use-websocket": "^4.13.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.25.17",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.25.9",
    "eslint": "^8.51.0",
    "eslint-config-next": "^15.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.1.6",
    "next-router-mock": "^1.0.2",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn": "^3.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "graphql": "15.10.1",
    "msw/graphql": "15.10.1"
  },
  "overrides": {
    "@aws-amplify/data-schema-types": {
      "graphql": "$graphql"
    },
    "@aws-amplify/api-graphql": {
      "graphql": "$graphql"
    },
    "msw": {
      "graphql": "$graphql"
    }
  }
}
