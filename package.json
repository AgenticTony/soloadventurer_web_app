{
  "name": "soloadventurer-web-app",
  "version": "1.0.0",
  "description": "A social platform for solo travelers",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy": "next build && next start",
    "prepare": "husky",
    "lint-staged": {
      "*.{js,jsx,ts,tsx}": [
        "eslint --fix",
        "prettier --write"
      ],
      "*.{json,css,md}": [
        "prettier --write"
      ]
    },
    "e2e": "cypress run"
  },
  "keywords": [
    "travel",
    "social",
    "nextjs",
    "react",
    "typescript",
    "aws"
  ],
  "author": "SoloAdventurer Team",
  "license": "MIT",
  "dependencies": {
    "@apollo/client": "^3.8.0",
    "@aws-amplify/adapter-nextjs": "^1.6.9",
    "@aws-amplify/ui-react": "^6.5.0",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.0.0",
    "aws-amplify": "^6.15.6",
    "aws-appsync-auth-link": "^3.0.0",
    "aws-appsync-subscription-link": "^3.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.11.0",
    "graphql": "^15.8.0",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^19.0.0-rc",
    "react-dom": "^19.0.0-rc",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.4.0",
    "react-intersection-observer": "^9.5.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.16.1",
    "@aws-amplify/backend-cli": "^1.8.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "autoprefixer": "^10.4.0",
    "aws-cdk-lib": "^2.204.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.25.9",
    "eslint": "^8.51.0",
    "eslint-config-next": "^15.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.1.6",
    "next-router-mock": "^1.0.2",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn": "^3.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "graphql": "15.10.1",
    "msw/graphql": "15.10.1"
  },
  "overrides": {
    "@aws-amplify/data-schema-types": {
      "graphql": "$graphql"
    },
    "@aws-amplify/api-graphql": {
      "graphql": "$graphql"
    },
    "msw": {
      "graphql": "$graphql"
    }
  }
}
