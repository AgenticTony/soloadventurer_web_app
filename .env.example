# AWS Amplify Configuration
# Replace these with your actual AWS Cognito and AppSync values
# These values will be automatically generated when you deploy with Amplify Gen 2

# AWS Region
AWS_REGION=us-east-1

# Authentication (Cognito)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_IDENTITY_POOL_ID=us-east-1:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# AppSync Configuration
APPSYNC_API_URL=https://XXXXXXXXXXXXXXXXXXXXXXXXXX.appsync-api.us-east-1.amazonaws.com/graphql
APPSYNC_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXX

# S3 Configuration (for file uploads)
S3_BUCKET_NAME=soloadventurer-storage-XXXXXXXXXXXX
S3_REGION=us-east-1

# Google Maps API (for location features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mapbox (for interactive maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here

# Application Configuration
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Environment
NODE_ENV=development