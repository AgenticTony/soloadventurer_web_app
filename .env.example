# Supabase Configuration (shared with mobile app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox (for interactive maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here

# API Configuration
NEXT_PUBLIC_API_BASE=http://localhost:3000/api
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://your-project.supabase.co/graphql/v1

# Application Configuration
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Product analytics — PostHog (EU Cloud, GDPR). Shares the mobile app's PostHog
# project so the visit→install→meetup funnel stitches. Analytics is OFF until a
# key is set AND the visitor opts in. See docs/analytics-v0.1.md.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
